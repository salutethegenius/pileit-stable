# PileIt WebRTC → LiveKit → Mux gateway (see README.md)

PORT=8787
PILEIT_API_URL=http://127.0.0.1:8000

# Must match backend LIVE_GATEWAY_SHARED_SECRET
LIVE_GATEWAY_SHARED_SECRET=

# Must match backend LIVE_BROWSER_INGEST_SECRET (or backend JWT_SECRET if that’s what you use in dev)
LIVE_BROWSER_INGEST_SECRET=
# Optional dev fallback if LIVE_BROWSER_INGEST_SECRET is empty:
# PILEIT_JWT_SECRET_FALLBACK=

# LiveKit server HTTP URL (Twirp), e.g. http://127.0.0.1:7880 or https://your-project.livekit.cloud
LIVEKIT_URL=
# Egress service HTTP URL (defaults to LIVEKIT_URL). Self-hosted egress often :8080
LIVEKIT_EGRESS_URL=
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=
# Browser connects here: wss://your-host or LiveKit Cloud websocket URL
LIVEKIT_PUBLIC_WS_URL=

# TURN day one — use Metered.ca / coturn / Twilio. Option A: single URL + user + pass
TURN_SERVER_URL=turn:global.turn.metered.ca:3478
TURN_USERNAME=
TURN_CREDENTIAL=

# Option B: full RTCConfiguration.iceServers JSON array (overrides TURN_* if set)
# ICE_SERVERS_JSON=[{"urls":"stun:stun.l.google.com:19302"},{"urls":"turn:global.turn.metered.ca:3478","username":"...","credential":"..."}]
