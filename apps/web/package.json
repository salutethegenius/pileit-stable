{
  "name": "web",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "cross-env NEXT_IGNORE_INCORRECT_LOCKFILE=1 portless pileit-web next dev",
    "dev:direct": "cross-env NEXT_IGNORE_INCORRECT_LOCKFILE=1 next dev",
    "build": "cross-env NEXT_IGNORE_INCORRECT_LOCKFILE=1 next build",
    "start": "cross-env NEXT_IGNORE_INCORRECT_LOCKFILE=1 next start",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "verify": "npm run lint && npm run typecheck && npm run build"
  },
  "engines": {
    "node": "20.x"
  },
  "dependencies": {
    "@babel/runtime": "^7.29.2",
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.0",
    "@mui/icons-material": "^5.16.14",
    "@mui/material": "^5.16.14",
    "@mui/material-nextjs": "^5.16.14",
    "framer-motion": "^12.38.0",
    "next": "14.2.35",
    "react": "^18",
    "react-dom": "^18",
    "react-slick": "^0.31.0",
    "slick-carousel": "^1.8.1"
  },
  "devDependencies": {
    "@types/node": "^20",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "@types/react-slick": "^0.23.13",
    "cross-env": "^7.0.3",
    "es-abstract": "^1.24.1",
    "eslint": "^8",
    "eslint-config-next": "14.2.35",
    "typescript": "^5"
  }
}
