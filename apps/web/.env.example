# Public site URL (no trailing slash) — required in production for SEO: canonicals, OG, sitemap, robots,
# and for WhatsApp / iMessage link previews (absolute og:image). Must match the live origin (e.g. https://www.pileit.app).
NEXT_PUBLIC_SITE_URL=http://localhost:3000
# Production & preview: set this on Vercel to your public domain so og:image is never a
# *.vercel.app URL (crawlers often get HTML → “invalid content type” for the image).
# NEXT_PUBLIC_SITE_URL=https://pileit.app

# With portless: API is routed at hostname pileit-api on the proxy port (default 1355).
NEXT_PUBLIC_API_URL=http://pileit-api.localhost:1355
# Direct mode (no portless): NEXT_PUBLIC_API_URL=http://127.0.0.1:8000

# Production (Vercel): set API_URL to your FastAPI origin (no trailing slash). Next.js rewrites
# /pileit-data/* → API so the browser can log in and load /creators without NEXT_PUBLIC_API_URL.
# Optional: also set NEXT_PUBLIC_API_URL to the same URL if you want direct browser calls (then CORS must allow the web origin).
# API_URL=https://your-api.up.railway.app

# Server-only API base for sitemap/ISR (same as API_URL / NEXT_PUBLIC_API_URL in prod).

NEXT_PUBLIC_KEMISPAY_PUBLIC_KEY=pk_test_stub
