# Relative sqlite paths are anchored to the backend/ folder (see app.config.Settings).
DATABASE_URL=sqlite:///./pileit.db
# Production (Railway Postgres): use DATABASE_URL from the linked Postgres service.
# RAILWAY_ENVIRONMENT triggers appending sslmode=require when missing (Railway Postgres expects TLS).
# Example manual URL: DATABASE_URL=postgresql://user:pass@host:5432/railway?sslmode=require
JWT_SECRET=change-me
JWT_REFRESH_SECRET=change-me-too
# Browser Origin must match or preflight OPTIONS returns 400. Include every frontend URL (https://…, no trailing slash).
# PUBLIC_WEB_URL is also merged into allowed origins (see app/main.py).
# Outside Railway, CORS also allows a regex for http://pileit-web.localhost:*, localhost:*, and
# 127.0.0.1:* so portless (ephemeral Next port, stable :1355 URL) works. Override with CORS_ORIGIN_REGEX if needed.
CORS_ORIGINS=http://pileit-web.localhost:1355,http://127.0.0.1:1355,http://localhost:3001,http://127.0.0.1:3001
# Optional: preview deploys, e.g. ^https://pileit-.*\\.vercel\\.app$
# CORS_ORIGIN_REGEX=
KEMISPAY_SECRET_KEY=sk_test_stub
KEMISPAY_API_URL=https://api.kemispay.com
PLATFORM_FEE_TIPS=0.15
PLATFORM_FEE_STORE=0.10

# Channel claim (magic link + Instagram DM)
# Production: must match the site users open in the browser (used for claim links and CORS).
PUBLIC_WEB_URL=http://localhost:3000
API_PUBLIC_URL=http://127.0.0.1:8000

# Mux Video — Direct Upload (server creates signed URL; browser PUTs the file)
# Dashboard → https://dashboard.mux.com/settings/access-tokens
MUX_TOKEN_ID=
MUX_TOKEN_SECRET=
# Optional — paste signing secret from Mux Dashboard → Webhooks for POST /mux/webhook
MUX_WEBHOOK_SECRET=

# Browser live (LiveKit egress → Mux). Use the same LIVE_GATEWAY_SHARED_SECRET on the gateway service.
# LIVE_BROWSER_INGEST_SECRET signs JWTs for browser→gateway (optional; falls back to JWT_SECRET if empty).
LIVE_GATEWAY_SHARED_SECRET=
LIVE_BROWSER_INGEST_SECRET=

# Optional: Railway Storage Bucket (S3-compatible) for creator avatar + hero images.
# Private bucket — browsers still use GET {API}/public-files/media/… (API proxies from S3).
# In Railway: create a Bucket, then reference its variables on the API service:
#   BUCKET, ENDPOINT, REGION, ACCESS_KEY_ID, SECRET_ACCESS_KEY
# If uploads fail, try S3_ADDRESSING_STYLE=path (older buckets).
# BUCKET=
# ENDPOINT=https://storage.railway.app
# REGION=auto
# ACCESS_KEY_ID=
# SECRET_ACCESS_KEY=
# S3_ADDRESSING_STYLE=virtual

# Meta / Instagram (channel claim + webhooks) — use Developer Console values in real `.env` only.
META_APP_ID=your-meta-app-id-here
META_APP_SECRET=your-meta-app-secret-here
META_INSTAGRAM_ACCESS_TOKEN=your-instagram-access-token-here
META_INSTAGRAM_BUSINESS_ACCOUNT_ID=your-instagram-business-account-id-here
META_WEBHOOK_VERIFY_TOKEN=your-webhook-verify-token-here
PILEIT_INSTAGRAM_USERNAME=PileItOfficial

# Meta Login (Facebook OAuth) — "Import from Facebook" feature.
# 1. Add the Facebook Login product in the Meta app dashboard.
# 2. Register this exact redirect URI under "Valid OAuth Redirect URIs":
#    https://<api-host>/social/meta/oauth/callback   (use http://127.0.0.1:8000/... locally)
# 3. Generate the Fernet key once and keep it stable — rotating breaks existing tokens:
#    python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
META_OAUTH_REDIRECT_URI=
META_TOKEN_ENCRYPTION_KEY=