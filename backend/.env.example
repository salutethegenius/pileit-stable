# Relative sqlite paths are anchored to the backend/ folder (see app.config.Settings).
DATABASE_URL=sqlite:///./pileit.db
# Production (Railway Postgres): leave DATABASE_URL unset in .env and use the variable injected by Railway, or set e.g.
# DATABASE_URL=postgresql://user:pass@host:5432/railway
JWT_SECRET=change-me
JWT_REFRESH_SECRET=change-me-too
# With portless (recommended): web at http://pileit-web.localhost:1355 — include both named host and loopback.
CORS_ORIGINS=http://pileit-web.localhost:1355,http://127.0.0.1:1355,http://localhost:3001,http://127.0.0.1:3001
KEMISPAY_SECRET_KEY=sk_test_stub
KEMISPAY_API_URL=https://api.kemispay.com
PLATFORM_FEE_TIPS=0.15
PLATFORM_FEE_STORE=0.10

# Channel claim (magic link + Instagram DM)
PUBLIC_WEB_URL=http://localhost:3000
API_PUBLIC_URL=http://127.0.0.1:8000


